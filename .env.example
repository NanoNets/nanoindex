# Required: Nanonets API key for document extraction
NANONETS_API_KEY=your_nanonets_api_key_here

# Optional: Override the LLM provider for tree search / summaries / answer generation.
# Defaults to Nanonets chat API if not set.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o
